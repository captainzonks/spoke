# ==============================================================================
# BASE ENVIRONMENT VARIABLES - SPOKE PLATFORM
# ==============================================================================
# Description: System-wide configuration shared across hub and all modules
# Author: Matt Barham
# Created: 2026-02-12
# Version: 1.0.0
# ==============================================================================
# INSTRUCTIONS:
#   1. Copy this file to shared/env/base.env
#   2. Edit all values to match your deployment
#   3. Never commit shared/env/base.env (it's gitignored)
# ==============================================================================

#==========================================================================
# INSTANCE CONFIGURATION
#==========================================================================

# Your instance name (used in container naming, logging, and identification)
INSTANCE_NAME=myserver

# Your domain (used in Traefik routing rules)
# Local testing: set DOMAIN=spoke.local and CDN_IPS= (empty) — use `make init-local`
# Production: set DOMAIN=your-domain.com and CDN_IPS=<your CDN IP ranges>
DOMAIN=example.com

# Timezone (TZ database format: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Path to this Spoke installation (absolute path, no trailing slash)
SPOKE_DIR=/path/to/spoke

# Derived paths (usually don't need to change)
SECRETS_DIR=${SPOKE_DIR}/secrets
APPDATA_DIR=${SPOKE_DIR}/appdata
LOCALTIME=/etc/localtime

#==========================================================================
# USER CONFIGURATION
#==========================================================================

# Host user ID (run `id -u` to find yours)
# Run `make init` to auto-detect this value
PUID=1000

# Docker group ID — MUST match your system's docker group for socket-proxy access
# Run `getent group docker | cut -d: -f3` to find yours, or `make init` to auto-detect
# Common values: Debian/Ubuntu=999, Fedora=1000, Arch=968
DGID=999

# Username (for container user mapping)
USERNAME=myuser

# Admin contact info (used by Authentik, CrowdSec, etc.)
ADMIN_NAME='Your Name'
ADMIN_EMAIL='you@example.com'
SERVICES_EMAIL='services@example.com'

#==========================================================================
# CA CERTIFICATES
#==========================================================================

# Host-side path to CA certificate bundle
# Arch Linux: /etc/ca-certificates/extracted/tls-ca-bundle.pem
# Debian/Ubuntu: /etc/ssl/certs/ca-certificates.crt
# RHEL/Fedora: /etc/pki/tls/certs/ca-bundle.crt
CA_CERT=/etc/ssl/certs/ca-certificates.crt

# Container-side paths (usually don't need to change)
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
CURL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

#==========================================================================
# DYNAMIC DNS (optional - for residential IPs using DuckDNS)
#==========================================================================

# Your DuckDNS subdomain name (just the name, not the full URL)
# Example: if your URL is myserver.duckdns.org, set DUCKDNS_DOMAIN=myserver
# Token goes in: secrets/duckdns/duckdns_token
# See: scripts/maintenance/update_duckdns.sh
DUCKDNS_DOMAIN=

#==========================================================================
# DOCKER CONFIGURATION
#==========================================================================

COMPOSE_BAKE=true
TINI_SUBREAPER= # add to allow tini to pickup subprocesses if not PID 1

#==========================================================================
# NETWORK CONFIGURATION
#==========================================================================

# Trusted local IP ranges
LOCAL_IPS=127.0.0.1/32,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12

# CDN IP ranges (Cloudflare shown as example - update for your CDN or leave empty for local)
CDN_IPS=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

# Socket proxy configuration
SPROXY_IP=192.168.33.1
SPROXY_PORT=2375
SPROXY=tcp://socket-proxy:2375

#==========================================================================
# HUB SERVICE IPS
#==========================================================================

# PostgreSQL (shared database)
POSTGRES_IP=192.168.35.50
POSTGRES_PORT=5432
POSTGRES_HOST=postgres-hub
POSTGRES_DB=postgres
POSTGRES_USER=postgres

# Redis (shared cache)
REDIS_IP_A=192.168.38.40
REDIS_IP_T=192.168.35.40
REDIS_PORT=6379

#==========================================================================
# METRICS (optional - used if monitoring module is enabled)
#==========================================================================

PROMETHEUS_IP=192.168.35.109
PROMETHEUS_PORT=9090
