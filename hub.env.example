# ==============================================================================
# HUB ENVIRONMENT VARIABLES - SPOKE PLATFORM
# ==============================================================================
# Description: Hub service versions and configuration
# Author: Matt Barham
# Created: 2026-02-12
# Modified: 2026-04-22
# Version: 1.0.1
# Host: Your Server
# ==============================================================================
# Type: Template
# Security Level: MEDIUM - Versions and static IPs (no secrets)
# Component: Spoke hub environment
# ==============================================================================
# INSTRUCTIONS:
#   1. Copy this file to shared/env/hub.env
#   2. Update versions and IPs as needed
#   3. Never commit shared/env/hub.env (it's gitignored)
# ==============================================================================

#==========================================================================
# CROWDSEC SECURITY ENGINE
#==========================================================================

# Set to false for local testing (no CrowdSec required)
# Set to true for production (CrowdSec must be running and secrets populated)
CROWDSEC_ENABLED=true

#==========================================================================
# CONTAINER IMAGES
#==========================================================================

# Docker socket proxy
SOCKET_PROXY_IMAGE=wollomatic/socket-proxy:1.11.4

# Traefik reverse proxy (custom build with startup reliability scripts)
TRAEFIK_TAG=3.6.13-custom
TRAEFIK_IMAGE=${INSTANCE_NAME}/traefik:${TRAEFIK_TAG}

# Authentik SSO authentication server
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server:2026.2.1

# CrowdSec security engine (custom build with non-root user)
CROWDSEC_TAG=v1.7.7-custom
CROWDSEC_IMAGE=${INSTANCE_NAME}/crowdsec:${CROWDSEC_TAG}

# PostgreSQL (custom build with user mapping)
POSTGRES_TAG=18.3-custom
POSTGRES_IMAGE=${INSTANCE_NAME}/postgres:${POSTGRES_TAG}

# Redis cache
REDIS_IMAGE=redis:8.6.2-alpine

#==========================================================================
# SOCKET PROXY CONFIGURATION
#==========================================================================

# Access control (CIDR of soxy network)
SP_ALLOWFROM=192.168.33.0/24

# API endpoint permissions
SP_ALLOW_GET="(/v1\\.[0-9]{1,3})?/(containers/json(\\?.*)?|containers/[a-zA-Z0-9_-]+/(json|logs|stats)(\\?.*)?|images/json(\\?.*)?|version|info|_ping|events(\\?.*)?|networks(\\?.*)?|volumes(\\?.*)?|networks/[a-zA-Z0-9_-]+|volumes/[a-zA-Z0-9_-]+|plugins(\\?.*)?)"
SP_ALLOW_HEAD="/v1\\.[0-9]{1,3}/(_ping)|(_ping)"
SP_ALLOW_POST="/v1\\.[0-9]{1,3}/(containers/create|containers/[a-zA-Z0-9_-]+/start|containers/[a-zA-Z0-9_-]+/stop|containers/[a-zA-Z0-9_-]+/restart|containers/[a-zA-Z0-9_-]+/wait|containers/prune|networks/prune|auth)"
SP_ALLOW_PUT="/v1\\.[0-9]{1,3}/(containers/[a-zA-Z0-9_-]+/update)"
SP_ALLOW_DELETE="/v1\\.[0-9]{1,3}/(containers/[a-zA-Z0-9_-]+)"

#==========================================================================
# TRAEFIK CONFIGURATION
#==========================================================================

TRAEFIK_IP_T=192.168.35.2
TRAEFIK_IP_S=192.168.33.2

# Agent API authentication (for headless/automated API access)
# AGENT_HTPASSWD_FILE is auto-set by traefik-entrypoint.sh from the
# agent_htpasswd_credentials secret. Generate with:
#   htpasswd -nbB agent <password> > secrets/traefik/agent_htpasswd_credentials

#==========================================================================
# AUTHENTIK CONFIGURATION
#==========================================================================

# Server network
AUTH_IP_T=192.168.35.201
AUTH_IP_A=192.168.38.201
AUTH_PORT_HTTP=9000
AUTH_PORT_HTTPS=9443

# Worker network
AUTH_IP_W_T=192.168.35.202
AUTH_IP_W_S=192.168.33.202
AUTH_IP_W_A=192.168.38.202

# Database
AUTHENTIK_POSTGRESQL__HOST=postgres-hub
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__NAME=authentik_db

# Email (configure for your SMTP provider)
AUTHENTIK_EMAIL__HOST=localhost
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__USE_TLS=false
AUTHENTIK_EMAIL__TIMEOUT=10

#==========================================================================
# CROWDSEC CONFIGURATION
#==========================================================================

CROWDSEC_IP_T=192.168.35.200
CROWDSEC_IP_S=192.168.33.200
CROWDSEC_PORT=8080
CROWDSEC_METRICS_PORT=6069
CROWDSEC_APPSEC_PORT=7423

# Database
CROWDSEC_PSQL_USER=crowdsec
CROWDSEC_PSQL_DB=crowdsec_db
# Plain text password — CrowdSec doesn't support Docker secrets for DB auth
CROWDSEC_PSQL_PASSWORD=CHANGE_ME

# Collections to install
CROWDSEC_COLLECTIONS="crowdsecurity/traefik crowdsecurity/whitelist-good-actors crowdsecurity/linux crowdsecurity/appsec-virtual-patching"

#==========================================================================
# SABLIER CONFIGURATION (On-demand container management)
#==========================================================================

SABLIER_IP_S=192.168.33.10
SABLIER_IP_T=192.168.35.10
